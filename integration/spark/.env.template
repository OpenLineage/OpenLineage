# Local values for the credential-requiring Spark integration tasks. Copy
# this file to .env (gitignored) in this directory and fill in the sections
# you need — each task loads it automatically, wherever it is invoked from.
# Variables set in the real environment take precedence over .env.

### task aws-integration-test ################################################
# AWS credentials themselves are taken from the ambient environment
# (e.g. AWS_PROFILE or AWS_ACCESS_KEY_ID/_SECRET_ACCESS_KEY).
#BUCKET=my-emr-tests-bucket
#SUBNET=subnet-0123456789abcdef0

### task abfss-test (Unity Catalog abfss integration tests) #################
# Required: a WRITABLE abfss:// base under which the tests create (and remove)
# tables. The storage account is derived from its authority. Plus an OAuth
# service principal (client id, client secret, tenant id): the embedded Unity
# Catalog server uses it to vend per-table credentials, and the tests use it for
# direct storage cleanup.
#OPENLINEAGE_TESTS_AZURE_CONTAINER_URI=abfss://CONTAINER@ACCOUNT.dfs.core.windows.net/test
#OPENLINEAGE_TESTS_AZURE_CLIENT_ID=
#OPENLINEAGE_TESTS_AZURE_CLIENT_SECRET=
#OPENLINEAGE_TESTS_AZURE_TENANT_ID=
