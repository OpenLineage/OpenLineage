{
  "eventType": "START",
  "eventTime": "${json-unit.any-string}",
  "job": {
    "namespace": "flink_job_namespace",
    "name": "flink_source_with_generic_record"
  },
  "run": {
    "runId": "${json-unit.any-string}",
    "facets": {
      "processing_engine": {
        "version": "${json-unit.regex}1\\.\\d+\\.\\d+",
        "name": "flink",
        "openlineageAdapterVersion": "${json-unit.any-string}"
      },
      "flink_job": {
        "jobId": "${json-unit.any-string}"
      },
      "tags": {
        "tags": [
          {
            "key": "openlineage_client_version",
            "value": "${json-unit.any-string}",
            "source": "OPENLINEAGE_CLIENT"
          }
        ]
      }
    }
  },
  "inputs": [
    {
      "namespace": "kafka://kafka-cluster-prod:9092",
      "name": "io.openlineage.flink.kafka.input_no_schema_registry",
      "facets": {
        "schema": {
          "fields": [
            {
              "name": "id",
              "type": "string"
            },
            {
              "name": "version",
              "type": "long"
            }
          ]
        }
      }
    }
  ],
  "outputs": [
    {
      "namespace": "kafka://kafka-cluster-prod:9092",
      "name": "io.openlineage.flink.kafka.output",
      "facets": {
        "schema": {
          "fields": [
            {
              "name": "id",
              "type": "string"
            },
            {
              "name": "version",
              "type": "long"
            },
            {
              "name": "counter",
              "type": "long"
            }
          ]
        }
      }
    }
  ]
}
