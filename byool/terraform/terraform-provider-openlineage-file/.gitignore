# Local dev override — contains the absolute path to bin/ on this machine.
# Every developer's path is different; committing it would break other checkouts.
.terraformrc

# go.work is machine-specific (local module replace directives).
go.work
go.work.sum

# Build output
bin/

# Terraform working files
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
**/lineage/

# Generated by make example — edit examples/ instead
terraform-example/

# docs generated by `make docs`
docs/