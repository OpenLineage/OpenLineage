{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openlineage.io/spec/facets/1-0-0/TestResultRunFacet.json",
  "$defs": {
    "TestResultRunFacet": {
      "description": "Result of a test execution, capturing test outcome and configured severity independently of dataset attribution.",
      "allOf": [
        {
          "$ref": "https://openlineage.io/spec/2-0-2/OpenLineage.json#/$defs/RunFacet"
        },
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "description": "The actual outcome of the test execution.",
              "enum": ["pass", "fail"],
              "example": "pass"
            },
            "severity": {
              "type": "string",
              "description": "The configured severity level of the test. Determines whether a failure blocks pipeline execution ('error') or produces a warning only ('warn').",
              "enum": ["error", "warn"],
              "example": "error"
            }
          },
          "required": ["status", "severity"]
        }
      ],
      "type": "object"
    }
  },
  "type": "object",
  "properties": {
    "testResult": {
      "$ref": "#/$defs/TestResultRunFacet"
    }
  }
}
